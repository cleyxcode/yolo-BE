# ══════════════════════════════════════════════
#  Konfigurasi Fish Freshness Detection
#  Salin file ini menjadi .env dan sesuaikan
# ══════════════════════════════════════════════

# Path ke model YOLO custom Anda
MODEL_PATH=best.pt

# Index kamera:
#   0 = webcam laptop bawaan
#   1 = webcam USB / kamera kedua
#   Untuk HP via DroidCam biasanya index 1 atau 2
CAMERA_INDEX=0

# Confidence threshold (0.0 - 1.0)
# Semakin tinggi = hanya deteksi yang yakin yang ditampilkan
CONFIDENCE=0.5

# Resolusi yang diminta ke kamera
FRAME_WIDTH=1280
FRAME_HEIGHT=720